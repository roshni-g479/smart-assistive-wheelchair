    winsound = None

current_tts_process = None

def stop_speak():
    global current_tts_process
    if current_tts_process and current_tts_process.poll() is None:
        try:
            current_tts_process.kill()
        except:
            pass

def speak(text):
    global current_tts_process
    stop_speak()
    script = f'''import pyttsx3
try:
    engine = pyttsx3.init()
    engine.say({repr(text)})
    engine.runAndWait()
except:
    pass
'''
    try:
        # CREATE_NO_WINDOW = 0x08000000 ensures no console popups on Windows
        current_tts_process = subprocess.Popen([sys.executable, "-c", script], creationflags=0x08000000)
    except Exception as e:
        print(f"TTS Start Error: {e}")



